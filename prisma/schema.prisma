// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}
model Subsidiary {
  id          String   @id
  name        String
  description String
  image       String
  createdAt   DateTime @default(now())
}
model BlogPost {
  id        String   @id
  title     String
  date      String
  category  String
  excerpt   String
  content   String
  image     String
  createdAt DateTime @default(now())
}

model JobOpening {
  id          String   @id
  title       String
  department  String
  location    String
  type        String
  description String
  deadline    String
  createdAt   DateTime @default(now())
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model JobApplication {
  id           Int      @id @default(autoincrement())
  jobId        String
  name         String
  email        String
  coverLetter  String
  createdAt    DateTime @default(now())
}
model Sector {
  id        String   @id
  title     String
  text      String
  image     String
  createdAt DateTime @default(now())
}

model TeamMember {
  id        Int      @id @default(autoincrement())
  name      String
  role      String
  image     String?
  order     Int      @default(0)
  bio       String?
  cv        String?
  createdAt DateTime @default(now())
}
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}
model AboutContent {
  id         Int    @id @default(autoincrement())
  background String
  vision     String
  mission    String
}

model CoreValue {
  id    Int    @id @default(autoincrement())
  title String
  text  String
}
model BoardMember {
  id        Int      @id @default(autoincrement())
  name      String
  role      String
  image     String?
  order     Int      @default(0)
  bio       String?
  cv        String?
  createdAt DateTime @default(now())
}
